generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  draft
  published
  archived
}

enum DivisionStatus {
  active
  inactive
  archived
}

enum MediaAssetKind {
  image
  video
  document
  model
  other
}

enum UserRole {
  admin
  editor
  viewer
}

enum InquiryStatus {
  new
  qualified
  contacted
  closed
  archived
}

enum SubscriptionStatus {
  active
  unsubscribed
  bounced
}

enum CareerApplicationStatus {
  new
  reviewed
  shortlisted
  rejected
  hired
}

enum ProjectStatus {
  concept
  active
  completed
  archived
}

enum ConsultationStatus {
  new
  reviewed
  contacted
  archived
}

enum WorkflowStageKey {
  consultation_submitted
  internal_review
  approval_verification
  strategy_discussion
  execution_planning
  project_kickoff
}

enum WorkflowStageStatus {
  locked
  active
  waiting
  completed
  rejected
}

enum UploadedDocumentKind {
  submission
  response
}

enum WorkflowAdminAction {
  approve
  reject
  move_next
  add_note
  update_status
  upload_response
}

model SiteConfig {
  id                String            @id @default(cuid())
  key               String            @unique @default("default")
  logoText          String            @default("Ractysh")
  seoTitle          String
  seoDescription    String            @db.Text
  seoKeywords       String[]          @default([])
  themeMode         String            @default("light")
  themeAccent       String            @default("#8b1118")
  footerHeadline    String
  footerDescription String            @db.Text
  footerLinks       Json              @default("[]")
  socialLinks       Json              @default("[]")
  popupConfig       Json?
  googleRatings     Json?
  feedbackConfig    Json?
  updatedAt         DateTime          @updatedAt
  createdAt         DateTime          @default(now())
  navItems          NavItem[]
  heroSections      HeroSection[]
  pageSections      PageSection[]
  contentRevisions  ContentRevision[]
}

model NavItem {
  id           String     @id @default(cuid())
  siteConfigId String
  parentId     String?
  label        String
  description  String?    @db.Text
  href         String
  position     Int        @default(0)
  visible      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  siteConfig   SiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)
  parent       NavItem?   @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     NavItem[]  @relation("NavTree")

  @@unique([siteConfigId, parentId, label])
  @@index([siteConfigId, position])
  @@index([parentId])
}

model HeroSection {
  id            String        @id @default(cuid())
  siteConfigId  String
  pageSlug      String        @default("home")
  eyebrow       String
  headline      String        @db.Text
  subheadline   String        @db.Text
  primaryCta    String?
  primaryHref   String?
  secondaryCta  String?
  secondaryHref String?
  trustLine     String?       @db.Text
  mediaUrl      String?
  status        PublishStatus @default(published)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  siteConfig    SiteConfig    @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@unique([siteConfigId, pageSlug])
  @@index([status])
}

model PageSection {
  id           String        @id @default(cuid())
  siteConfigId String
  pageSlug     String
  key          String
  label        String
  visible      Boolean       @default(true)
  position     Int           @default(0)
  content      Json          @default("{}")
  status       PublishStatus @default(published)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  siteConfig   SiteConfig    @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)

  @@unique([siteConfigId, pageSlug, key])
  @@index([pageSlug, position])
  @@index([status])
}

model CompanyDivision {
  id             String          @id @default(cuid())
  slug           String          @unique
  name           String
  legalName      String          @unique
  summary        String          @db.Text
  description    String?         @db.Text
  metric         String?
  registrationNo String?
  foundedYear    Int?
  website        String?
  brandColor     String          @default("#8b1118")
  accentColor    String          @default("#d6b45f")
  status         DivisionStatus  @default(active)
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  services       ServiceOffer[]
  projects       Project[]
  teamMembers    TeamMember[]
  locations      Location[]
  mediaAssets    MediaAsset[]
  statistics     Statistic[]
  certifications Certification[]
  timelineEvents TimelineEvent[]
  careerJobs     CareerJob[]

  @@index([status, position])
}

model ServiceOffer {
  id           String           @id @default(cuid())
  companyId    String
  slug         String           @unique
  title        String
  summary      String           @db.Text
  description  String?          @db.Text
  category     String
  href         String?
  imageUrl     String?
  tags         String[]         @default([])
  status       PublishStatus    @default(published)
  position     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      CompanyDivision  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectLinks ProjectService[]
  mediaAssets  MediaAsset[]

  @@index([companyId, position])
  @@index([category])
  @@index([status])
}

model Project {
  id           String           @id @default(cuid())
  companyId    String
  slug         String           @unique
  title        String
  category     String
  location     String
  summary      String           @db.Text
  description  String?          @db.Text
  year         String
  status       ProjectStatus    @default(concept)
  clientName   String?
  imageUrl     String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      CompanyDivision  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceLinks ProjectService[]
  mediaAssets  MediaAsset[]

  @@index([companyId, status])
  @@index([category])
  @@index([year])
}

model ProjectService {
  projectId      String
  serviceOfferId String
  assignedAt     DateTime     @default(now())
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceOffer   ServiceOffer @relation(fields: [serviceOfferId], references: [id], onDelete: Cascade)

  @@id([projectId, serviceOfferId])
  @@index([serviceOfferId])
}

model MediaAsset {
  id           String           @id @default(cuid())
  kind         MediaAssetKind   @default(image)
  title        String
  altText      String?
  url          String
  provider     String           @default("local")
  providerId   String?
  mimeType     String?
  size         Int?
  width        Int?
  height       Int?
  metadata     Json?
  companyId    String?
  serviceId    String?
  projectId    String?
  teamMemberId String?
  blogPostId   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  service      ServiceOffer?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  teamMember   TeamMember?      @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  blogPost     BlogPost?        @relation(fields: [blogPostId], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([companyId])
  @@index([serviceId])
  @@index([projectId])
  @@index([teamMemberId])
  @@index([blogPostId])
}

model TeamMember {
  id                  String           @id @default(cuid())
  companyId           String?
  slug                String           @unique
  name                String
  role                String
  position            String?
  biography           String?          @db.Text
  leadershipStatement String?          @db.Text
  imageUrl            String?
  email               String?
  phone               String?
  socialLinks         Json             @default("[]")
  achievements        String[]         @default([])
  awards              String[]         @default([])
  gallery             String[]         @default([])
  isFounder           Boolean          @default(false)
  isDirector          Boolean          @default(false)
  positionOrder       Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  company             CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  mediaAssets         MediaAsset[]
  certifications      Certification[]
  timelineEvents      TimelineEvent[]
  blogPosts           BlogPost[]

  @@index([companyId])
  @@index([isFounder, isDirector])
}

model BlogPost {
  id          String        @id @default(cuid())
  authorId    String?
  slug        String        @unique
  title       String
  category    String
  excerpt     String        @db.Text
  body        String?       @db.Text
  imageUrl    String?
  readingTime String?
  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      TeamMember?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  mediaAssets MediaAsset[]

  @@index([status, publishedAt])
  @@index([category])
}

model Statistic {
  id        String           @id @default(cuid())
  companyId String?
  scope     String           @default("global")
  label     String
  value     Int
  suffix    String           @default("")
  position  Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([scope, label])
  @@index([companyId])
  @@index([scope, position])
}

model Testimonial {
  id          String   @id @default(cuid())
  quote       String   @db.Text
  name        String
  role        String
  companyName String?
  rating      Int?
  approved    Boolean  @default(false)
  source      String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([approved, position])
}

model Location {
  id              String           @id @default(cuid())
  companyId       String?
  name            String
  address         String           @db.Text
  outlookLocation String?
  city            String?
  state           String?
  country         String           @default("India")
  postalCode      String?
  phone           String?
  email           String?
  hours           String?
  mapEmbedUrl     String?          @db.Text
  position        Int              @default(0)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([active, position])
}

model LegalDocument {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  summary     String    @db.Text
  body        String    @db.Text
  fileUrl     String?
  effectiveAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Certification {
  id           String           @id @default(cuid())
  companyId    String?
  teamMemberId String?
  title        String
  issuer       String
  year         String
  fileUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  teamMember   TeamMember?      @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([teamMemberId])
}

model TimelineEvent {
  id           String           @id @default(cuid())
  companyId    String?
  teamMemberId String?
  year         String
  title        String
  description  String           @db.Text
  position     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      CompanyDivision? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  teamMember   TeamMember?      @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)

  @@index([companyId, position])
  @@index([teamMemberId, position])
}

model Partner {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @db.Text
  website     String?
  logoUrl     String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CareerJob {
  id           String              @id @default(cuid())
  companyId    String?
  slug         String              @unique
  title        String
  location     String
  type         String
  summary      String              @db.Text
  description  String?             @db.Text
  status       PublishStatus       @default(published)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  company      CompanyDivision?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  applications CareerApplication[]

  @@index([companyId])
  @@index([status])
}

model CareerApplication {
  id           String                  @id @default(cuid())
  jobId        String?
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  portfolioUrl String?
  coverLetter  String?                 @db.Text
  status       CareerApplicationStatus @default(new)
  notes        String?                 @db.Text
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  job          CareerJob?              @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([email])
  @@index([status])
}

model ContactInquiry {
  id          String        @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  companyName String?
  interest    String?
  message     String        @db.Text
  status      InquiryStatus @default(new)
  source      String        @default("website")
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([email])
  @@index([status, createdAt])
}

model ServiceRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String
  route     String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([service])
  @@index([createdAt])
}

model Subscription {
  id             String             @id @default(cuid())
  email          String             @unique
  source         String             @default("website")
  status         SubscriptionStatus @default(active)
  consentAt      DateTime           @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model AdminUser {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String?
  role             UserRole          @default(admin)
  active           Boolean           @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  contentRevisions ContentRevision[]
}

model AuditLog {
  id         String     @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())
  actor      AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ContentRevision {
  id           String     @id @default(cuid())
  siteConfigId String
  authorId     String?
  label        String
  content      Json
  published    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  siteConfig   SiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)
  author       AdminUser? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([siteConfigId, createdAt])
  @@index([authorId])
}

model Consultation {
  id                        String             @id @default(cuid())
  trackingToken             String             @unique @default(uuid())
  fullName                  String
  companyName               String
  emailAddress              String
  phoneNumber               String
  serviceType               String
  budgetRange               String
  projectTimeline           String
  projectDescription        String             @db.Text
  preferredConsultationType String
  source                    String             @default("book-consultation-page")
  status                    ConsultationStatus @default(new)
  currentStageKey           WorkflowStageKey   @default(internal_review)
  notificationSent          Boolean            @default(false)
  notificationSkipped       Boolean            @default(false)
  notificationError         String?
  notificationSentAt        DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  workflowStages            WorkflowStage[]
  workflowLogs              WorkflowLog[]
  uploadedDocuments         UploadedDocument[]
  adminActions              AdminAction[]
  statusHistory             StatusHistory[]

  @@index([emailAddress])
  @@index([status])
  @@index([currentStageKey])
  @@index([createdAt])
}

model WorkflowStage {
  id                String              @id @default(cuid())
  consultationId    String
  key               WorkflowStageKey
  title             String
  description       String              @db.Text
  position          Int
  status            WorkflowStageStatus @default(locked)
  stateLabel        String              @default("Locked")
  adminNotes        String?             @db.Text
  startedAt         DateTime?
  unlockedAt        DateTime?
  completedAt       DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  consultation      Consultation        @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  workflowLogs      WorkflowLog[]
  uploadedDocuments UploadedDocument[]
  adminActions      AdminAction[]
  statusHistory     StatusHistory[]

  @@unique([consultationId, key])
  @@index([consultationId, position])
  @@index([status])
}

model WorkflowLog {
  id             String            @id @default(cuid())
  consultationId String
  stageId        String?
  stageKey       WorkflowStageKey?
  action         String
  actorId        String?
  actorEmail     String?
  actorRole      String?
  note           String?           @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now())
  consultation   Consultation      @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  stage          WorkflowStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([consultationId, createdAt])
  @@index([stageId])
}

model UploadedDocument {
  id             String               @id @default(cuid())
  consultationId String
  stageId        String?
  stageKey       WorkflowStageKey?
  kind           UploadedDocumentKind @default(submission)
  filename       String
  mimeType       String
  size           Int
  url            String?
  provider       String               @default("metadata")
  providerId     String?
  uploadedBy     String               @default("client")
  createdAt      DateTime             @default(now())
  consultation   Consultation         @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  stage          WorkflowStage?       @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([consultationId, kind])
  @@index([stageId])
}

model AdminAction {
  id             String              @id @default(cuid())
  consultationId String
  stageId        String?
  stageKey       WorkflowStageKey?
  action         WorkflowAdminAction
  statusBefore   String?
  statusAfter    String?
  notes          String?             @db.Text
  adminId        String?
  adminEmail     String?
  createdAt      DateTime            @default(now())
  consultation   Consultation        @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  stage          WorkflowStage?      @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([consultationId, createdAt])
  @@index([stageId])
}

model StatusHistory {
  id             String            @id @default(cuid())
  consultationId String
  stageId        String?
  stageKey       WorkflowStageKey?
  fromStatus     String?
  toStatus       String
  label          String?
  changedBy      String?
  note           String?           @db.Text
  createdAt      DateTime          @default(now())
  consultation   Consultation      @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  stage          WorkflowStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([consultationId, createdAt])
  @@index([stageId])
}
