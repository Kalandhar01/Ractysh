generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServiceRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String
  route     String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([service])
  @@index([createdAt])
}
